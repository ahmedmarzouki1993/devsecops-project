# .env.example — copy to .env for local development (outside docker-compose)
#
# WHY this file?
#   When running the backend directly with `uvicorn app.main:app` (not via docker-compose),
#   pydantic-settings reads this .env file to configure the app.
#   The .env file is gitignored — this .env.example is the template to share safely.
#
# HOW to use:
#   cp .env.example .env
#   # Edit .env with your actual values
#   uvicorn app.main:app --reload

# PostgreSQL connection URL
# For local dev (direct): point at your local postgres instance
# For docker-compose: this is overridden by the `environment:` block in docker-compose.yml
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/devsecops

# Application environment — controls SQLAlchemy echo (SQL logging in development)
# Values: development | production
APP_ENV=development

# Log level for uvicorn
# Values: debug | info | warning | error | critical
LOG_LEVEL=info
